---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  /** Tailwind classes applied to <body> to set the page theme background + base text colour */
  themeClass?: string
}

const {
  title,
  description = 'Summer — management & leadership, care, and hairdressing.',
  themeClass = 'bg-white text-slate-900',
} = Astro.props

const nav = [
  { href: '/', label: 'Home' },
  { href: '/management/', label: 'Leadership' },
  { href: '/care/', label: 'Care' },
  { href: '/hairdressing/', label: 'Hairdressing' },
  { href: '/army/', label: 'Army Trainer' },
  { href: '/investigator/', label: 'PI' },
  { href: '/hitwoman/', label: 'Hitwoman' },
  { href: '/tattoo/', label: 'Tattoo' },
]

const path = Astro.url.pathname
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class={`min-h-dvh antialiased ${themeClass}`}>
    <header class="sticky top-0 z-50 border-b border-black/10 bg-white/70 backdrop-blur">
      <nav class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-3">
        <div class="flex items-center gap-2">
          <a href="/" class="flex items-center gap-2 font-bold text-slate-900">
            <span class="inline-block h-3 w-3 rounded-full bg-pink-500"></span>
            Summer
          </a>
          <button
            type="button"
            id="confetti-btn"
            aria-label="Shower the page with glitter"
            title="Glitter!"
            class="rounded-full bg-gradient-to-br from-pink-400 to-fuchsia-600 px-2.5 py-1 text-sm text-white shadow-sm transition-transform hover:scale-110 active:scale-95"
          >
            ✨
          </button>
        </div>
        <ul class="flex flex-wrap items-center gap-1 text-sm">
          {
            nav.map((item) => {
              const active = path === item.href
              return (
                <li>
                  <a
                    href={item.href}
                    class={`rounded-full px-3 py-1.5 font-medium transition-colors ${
                      active
                        ? 'bg-pink-500 text-white'
                        : 'text-slate-600 hover:bg-pink-100 hover:text-slate-900'
                    }`}
                  >
                    {item.label}
                  </a>
                </li>
              )
            })
          }
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-black/10 bg-white/60 py-8 text-center text-sm text-slate-500">
      <p>© {new Date().getFullYear()} Summer. Made with pink hair and good vibes.</p>
    </footer>

    <canvas
      id="confetti-canvas"
      class="pointer-events-none fixed inset-0 z-[100] hidden h-full w-full"
    ></canvas>

    <script>
      const btn = document.getElementById('confetti-btn')
      const canvas = document.getElementById('confetti-canvas') as HTMLCanvasElement | null
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches

      if (btn && canvas) {
        const ctx = canvas.getContext('2d')!
        const colours = ['#ec4899', '#f472b6', '#db2777', '#f9a8d4', '#facc15', '#fde68a', '#ffffff']

        interface Bit {
          x: number
          y: number
          vx: number
          vy: number
          size: number
          rot: number
          vr: number
          colour: string
          life: number
        }

        let bits: Bit[] = []
        let raf = 0

        function resize() {
          if (!canvas) return
          canvas.width = window.innerWidth
          canvas.height = window.innerHeight
        }
        window.addEventListener('resize', resize)
        resize()

        function burst() {
          if (!canvas) return
          const count = reduce ? 40 : 160
          const cx = canvas.width / 2
          for (let i = 0; i < count; i++) {
            const angle = (Math.PI * 2 * i) / count + Math.random()
            const speed = 4 + Math.random() * 9
            bits.push({
              x: cx + (Math.random() - 0.5) * 120,
              y: -20 - Math.random() * 80,
              vx: Math.cos(angle) * speed * 0.4,
              vy: Math.sin(angle) * speed * 0.2 + Math.random() * 3,
              size: 4 + Math.random() * 6,
              rot: Math.random() * Math.PI,
              vr: (Math.random() - 0.5) * 0.4,
              colour: colours[Math.floor(Math.random() * colours.length)],
              life: 1,
            })
          }
          canvas.classList.remove('hidden')
          if (!raf) raf = requestAnimationFrame(tick)
        }

        function tick() {
          if (!canvas) return
          ctx.clearRect(0, 0, canvas.width, canvas.height)
          bits = bits.filter((b) => b.life > 0 && b.y < canvas.height + 40)
          for (const b of bits) {
            b.vy += 0.18
            b.vx *= 0.99
            b.x += b.vx
            b.y += b.vy
            b.rot += b.vr
            b.life -= 0.006
            ctx.save()
            ctx.translate(b.x, b.y)
            ctx.rotate(b.rot)
            ctx.globalAlpha = Math.max(0, Math.min(1, b.life))
            ctx.fillStyle = b.colour
            ctx.fillRect(-b.size / 2, -b.size / 2, b.size, b.size * 0.6)
            ctx.restore()
          }
          if (bits.length > 0) {
            raf = requestAnimationFrame(tick)
          } else {
            raf = 0
            canvas.classList.add('hidden')
          }
        }

        btn.addEventListener('click', burst)
      }
    </script>
  </body>
</html>
