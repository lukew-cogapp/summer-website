---
import Layout from '../layouts/Layout.astro'

const areas = [
  {
    href: '/management/',
    title: 'Management & Leadership',
    blurb:
      'Leading teams, running smooth operations and bringing out the best in people. From rotas to strategy, I keep things calm, organised and moving forward.',
    accent: 'indigo',
    ring: 'group-hover:ring-indigo-300',
    bar: 'bg-indigo-500',
    chip: 'bg-indigo-50 text-indigo-700',
    link: 'text-indigo-600',
    glow: 'group-hover:shadow-indigo-200/60',
    icon: '◆',
  },
  {
    href: '/care/',
    title: 'Care',
    blurb:
      'Caring for children, vulnerable adults and the elderly with patience and warmth. I treat every person with the dignity and attention they deserve.',
    accent: 'teal',
    ring: 'group-hover:ring-teal-300',
    bar: 'bg-teal-500',
    chip: 'bg-teal-50 text-teal-700',
    link: 'text-teal-600',
    glow: 'group-hover:shadow-teal-200/60',
    icon: '♥',
  },
  {
    href: '/hairdressing/',
    title: 'Hairdressing',
    blurb:
      'Cutting, colour and styling that helps people feel like themselves. Salon-trained, colour-obsessed, and yes, the pink is self-inflicted (proudly).',
    accent: 'fuchsia',
    ring: 'group-hover:ring-fuchsia-300',
    bar: 'bg-fuchsia-500',
    chip: 'bg-fuchsia-50 text-fuchsia-700',
    link: 'text-fuchsia-600',
    glow: 'group-hover:shadow-fuchsia-200/60',
    icon: '✂',
  },
  {
    href: '/army/',
    title: 'Army Trainer',
    blurb:
      'Physical training instruction, drill and discipline. I push recruits to find their limits and then go past them, building leadership under pressure and the kind of resilience that lasts.',
    dark: true,
    ring: 'group-hover:ring-fuchsia-500/50',
    bar: 'bg-fuchsia-500',
    chip: 'bg-fuchsia-500/15 text-fuchsia-300',
    link: 'text-fuchsia-300',
    glow: 'group-hover:shadow-fuchsia-900/40',
    icon: '★',
  },
]
---

<Layout
  title="Summer"
  description="Summer — a friendly multi-talented professional working across leadership, care and hairdressing."
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute -top-24 right-0 -z-10 h-72 w-72 rounded-full bg-pink-200/50 blur-3xl"
    >
    </div>
    <div class="mx-auto max-w-5xl px-4 py-20 sm:py-28">
      <p class="mb-4 inline-flex items-center gap-2 rounded-full bg-pink-100 px-4 py-1.5 text-sm font-medium text-pink-700">
        <span class="inline-block h-2 w-2 rounded-full bg-pink-500"></span>
        Hello, I'm Summer
      </p>
      <h1 class="text-5xl font-extrabold tracking-tight text-slate-900 sm:text-7xl">
        One person,
        <span class="text-pink-500">three</span> passions.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600 sm:text-xl">
        I'm a leader, a carer and a hairdresser, and somehow it all makes sense.
        I love organising teams, looking after the people who need it most, and
        sending folks home with hair they adore. The pink hair? Consider it a
        permanent name badge.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href="#areas"
          class="inline-flex items-center gap-2 rounded-full bg-pink-500 px-6 py-3 font-semibold text-white shadow-lg shadow-pink-300/50 transition hover:bg-pink-600 hover:shadow-pink-400/50"
        >
          Explore my work
          <span aria-hidden="true">↓</span>
        </a>
        <a
          href="mailto:summer@example.com"
          class="inline-flex items-center gap-2 rounded-full border border-slate-300 px-6 py-3 font-semibold text-slate-700 transition hover:border-pink-300 hover:text-pink-600"
        >
          Say hello
        </a>
      </div>
    </div>
  </section>

  <!-- Three areas -->
  <section id="areas" class="mx-auto max-w-5xl scroll-mt-20 px-4 pb-8">
    <h2 class="mb-2 text-2xl font-bold text-slate-900 sm:text-3xl">
      Where I work
    </h2>
    <p class="mb-8 text-slate-600">
      Three distinct worlds, one curious mind. Pick one to dive in.
    </p>
    <div class="grid gap-6 sm:grid-cols-2">
      {
        areas.map((area) => (
          <a
            href={area.href}
            class={`group relative flex flex-col rounded-3xl p-7 ring-1 transition duration-300 hover:-translate-y-2 hover:shadow-2xl ${area.ring} ${area.glow} ${
              area.dark
                ? 'bg-stone-900 ring-stone-700'
                : 'bg-white ring-slate-200'
            }`}
          >
            <span class={`mb-5 h-1.5 w-12 rounded-full ${area.bar}`} />
            <span
              class={`mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl text-lg ${area.chip}`}
              aria-hidden="true"
            >
              {area.icon}
            </span>
            <h3 class={`text-xl font-bold ${area.dark ? 'text-white' : 'text-slate-900'}`}>
              {area.title}
            </h3>
            <p
              class={`mt-3 flex-1 text-sm leading-relaxed ${area.dark ? 'text-stone-300' : 'text-slate-600'}`}
            >
              {area.blurb}
            </p>
            <span
              class={`mt-6 inline-flex items-center gap-1.5 text-sm font-semibold transition-transform group-hover:gap-3 ${area.link}`}
            >
              Explore
              <span aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- About -->
  <section class="mx-auto max-w-5xl px-4 py-20">
    <div class="rounded-3xl bg-pink-50 p-8 sm:p-12">
      <h2 class="text-2xl font-bold text-slate-900 sm:text-3xl">
        A little about me
      </h2>
      <p class="mt-4 max-w-3xl text-lg leading-relaxed text-slate-700">
        I've never been very good at picking just one thing. Over the years I've
        run busy teams, supported people through some of their hardest days, and
        learned to wield a pair of scissors like they owe me money. What ties it
        all together is people: understanding them, helping them, and making
        their day a little brighter.
      </p>
      <p class="mt-4 max-w-3xl text-lg leading-relaxed text-slate-700">
        When I'm not working you'll find me topping up the pink, hunting for the
        perfect coffee, and saying yes to far too many plans.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-5xl px-4 pb-24">
    <div class="rounded-3xl bg-slate-900 px-8 py-14 text-center sm:px-12">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">
        Let's work together
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-slate-300">
        Got a role, a project or a fringe emergency? I'd love to hear from you.
      </p>
      <a
        href="mailto:summer@example.com"
        class="mt-8 inline-flex items-center gap-2 rounded-full bg-pink-500 px-8 py-4 text-lg font-semibold text-white shadow-lg shadow-pink-500/30 transition hover:bg-pink-400"
      >
        Get in touch
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</Layout>
