---
import Layout from '../layouts/Layout.astro'

const base = import.meta.env.BASE_URL
/** Join the configured base path with a leading-slash route. */
const withBase = (p: string) => `${base.replace(/\/$/, '')}${p}`

// Every card shares one light surface for a cohesive grid; each keeps its own
// accent colour (bar, icon chip, link, hover ring/glow) to preview the page.
const areas = [
  {
    // Leadership: violet/indigo accent
    href: withBase('/management/'),
    title: 'Management & Leadership',
    blurb:
      'Leading teams, running smooth operations and bringing out the best in people. From rotas to strategy, I keep things calm, organised and moving forward.',
    surface: 'bg-white ring-violet-100',
    titleText: 'text-slate-900',
    bodyText: 'text-slate-600',
    ring: 'group-hover:ring-violet-300',
    bar: 'bg-gradient-to-r from-violet-500 to-indigo-500',
    chip: 'bg-violet-100 text-violet-700',
    link: 'text-violet-600',
    glow: 'group-hover:shadow-violet-200/60',
    icon: '◆',
  },
  {
    // Care: teal + peach accent
    href: withBase('/care/'),
    title: 'Care',
    blurb:
      'Caring for children, vulnerable adults and the elderly with patience and warmth. I treat every person with the dignity and attention they deserve.',
    surface: 'bg-white ring-teal-100',
    titleText: 'text-slate-900',
    bodyText: 'text-slate-600',
    ring: 'group-hover:ring-teal-300',
    bar: 'bg-gradient-to-r from-teal-500 to-orange-300',
    chip: 'bg-teal-100 text-teal-700',
    link: 'text-teal-700',
    glow: 'group-hover:shadow-teal-200/60',
    icon: '♥',
  },
  {
    // Hairdressing: fuchsia/rose accent
    href: withBase('/hairdressing/'),
    title: 'Hairdressing',
    blurb:
      'Cutting, colour and styling that helps people feel like themselves. Salon-trained, colour-obsessed, and yes, the pink is self-inflicted (proudly).',
    surface: 'bg-white ring-pink-100',
    titleText: 'text-slate-900',
    bodyText: 'text-slate-600',
    ring: 'group-hover:ring-fuchsia-300',
    bar: 'bg-gradient-to-r from-pink-500 to-fuchsia-500',
    chip: 'bg-fuchsia-100 text-fuchsia-700',
    link: 'text-fuchsia-600',
    glow: 'group-hover:shadow-fuchsia-200/60',
    icon: '✂',
  },
  {
    // Army: rose/pink-camo accent
    href: withBase('/army/'),
    title: 'Army Trainer',
    blurb:
      'Physical training instruction, drill and discipline. I push recruits to find their limits and then go past them, building leadership under pressure and the kind of resilience that lasts.',
    surface: 'bg-white ring-rose-100',
    titleText: 'text-slate-900',
    bodyText: 'text-slate-600',
    ring: 'group-hover:ring-rose-300',
    bar: 'bg-gradient-to-r from-rose-500 via-pink-700 to-stone-600',
    chip: 'bg-rose-100 text-rose-700',
    link: 'text-rose-600',
    glow: 'group-hover:shadow-rose-200/60',
    icon: '★',
  },
  {
    // PI: amber/gold noir accent
    href: withBase('/investigator/'),
    title: 'Private Investigator',
    blurb:
      'Discreet investigations, surveillance and background checks. Whether it is a missing person or a quiet question that needs answering, I dig until the truth turns up.',
    surface: 'bg-white ring-amber-100',
    titleText: 'text-slate-900',
    bodyText: 'text-slate-600',
    ring: 'group-hover:ring-amber-300',
    bar: 'bg-gradient-to-r from-amber-400 to-amber-600',
    chip: 'bg-amber-100 text-amber-700',
    link: 'text-amber-600',
    glow: 'group-hover:shadow-amber-200/60',
    icon: '◉',
  },
  {
    // Hitwoman: hot-pink reticle accent
    href: withBase('/hitwoman/'),
    title: 'Hitwoman',
    blurb:
      'Elite operative for hire (entirely fictional). Stealth, disguise and getaway driving that would make a stunt coordinator blush. No targets were harmed in the making of this CV.',
    surface: 'bg-white ring-pink-100',
    titleText: 'text-slate-900',
    bodyText: 'text-slate-600',
    ring: 'group-hover:ring-pink-300',
    bar: 'bg-gradient-to-r from-pink-500 to-rose-600',
    chip: 'bg-pink-100 text-pink-700',
    link: 'text-pink-600',
    glow: 'group-hover:shadow-pink-200/60',
    icon: '⊕',
  },
  {
    // Tattoo: grey + neon hot-pink accent
    href: withBase('/tattoo/'),
    title: 'Tattoo Artist',
    blurb:
      'Black and grey realism, fine line and fully custom designs. I also love a clever cover-up, turning a regret into something you will actually want to show off.',
    surface: 'bg-white ring-neutral-200',
    titleText: 'text-slate-900',
    bodyText: 'text-slate-600',
    ring: 'group-hover:ring-pink-300',
    bar: 'bg-gradient-to-r from-neutral-400 via-pink-500 to-neutral-400',
    chip: 'bg-pink-100 text-pink-700',
    link: 'text-pink-600',
    glow: 'group-hover:shadow-pink-200/60',
    icon: '✶',
  },
  {
    // Undertaker: pink-goth fuchsia accent
    href: withBase('/undertaker/'),
    title: 'Undertaker',
    blurb:
      'Funeral directing with heart and serious style. I guide families through the hardest days with warmth, calm and a little pink-goth personality.',
    surface: 'bg-white ring-fuchsia-100',
    titleText: 'text-slate-900',
    bodyText: 'text-slate-600',
    ring: 'group-hover:ring-fuchsia-300',
    bar: 'bg-gradient-to-r from-fuchsia-500 to-pink-500',
    chip: 'bg-fuchsia-100 text-fuchsia-700',
    link: 'text-fuchsia-600',
    glow: 'group-hover:shadow-fuchsia-200/60',
    icon: '☠',
  },
]
---

<Layout
  title="Summer"
  description="Summer — a friendly multi-talented professional working across leadership, care, hairdressing and more."
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute -top-24 right-0 -z-10 h-72 w-72 rounded-full bg-pink-200/50 blur-3xl"
    >
    </div>
    <div class="mx-auto max-w-5xl px-4 py-20 sm:py-28">
      <p class="mb-4 inline-flex items-center gap-2 rounded-full bg-pink-100 px-4 py-1.5 text-sm font-medium text-pink-700">
        <span class="inline-block h-2 w-2 rounded-full bg-pink-500"></span>
        Hello, I'm Summer
      </p>
      <h1 class="text-5xl font-extrabold tracking-tight text-slate-900 sm:text-7xl">
        One person,
        <span class="text-pink-500">eight</span> worlds.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-600 sm:text-xl">
        Leader, carer, hairdresser, drill instructor, private eye, elite operative
        (allegedly), tattoo artist and funeral director. I've never been good at
        picking just one thing, and somehow it all makes sense. The pink hair?
        Consider it a permanent name badge.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href="#areas"
          class="inline-flex items-center gap-2 rounded-full bg-pink-500 px-6 py-3 font-semibold text-white shadow-lg shadow-pink-300/50 transition hover:bg-pink-600 hover:shadow-pink-400/50"
        >
          Explore my work
          <span aria-hidden="true">↓</span>
        </a>
        <a
          href="mailto:summer@example.com"
          class="inline-flex items-center gap-2 rounded-full border border-slate-300 px-6 py-3 font-semibold text-slate-700 transition hover:border-pink-300 hover:text-pink-600"
        >
          Say hello
        </a>
      </div>
    </div>
  </section>

  <!-- Three areas -->
  <section id="areas" class="mx-auto max-w-5xl scroll-mt-20 px-4 pb-8">
    <h2 class="mb-2 text-2xl font-bold text-slate-900 sm:text-3xl">
      Where I work
    </h2>
    <p class="mb-8 text-slate-600">
      Eight distinct worlds, one curious mind. Pick one to dive in.
    </p>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        areas.map((area, i) => (
          <a
            href={area.href}
            class={`group relative flex flex-col rounded-3xl p-7 ring-1 transition duration-300 hover:-translate-y-2 hover:shadow-2xl ${area.surface} ${area.ring} ${area.glow} ${
              i === 0 ? 'sm:col-span-2 lg:col-span-3' : ''
            }`}
          >
            <span class={`mb-5 h-1.5 w-12 rounded-full ${area.bar}`} />
            <span
              class={`mb-4 inline-flex h-11 w-11 items-center justify-center rounded-xl text-lg ${area.chip}`}
              aria-hidden="true"
            >
              {area.icon}
            </span>
            <h3 class={`text-xl font-bold ${area.titleText}`}>
              {area.title}
            </h3>
            <p
              class={`mt-3 flex-1 text-sm leading-relaxed ${area.bodyText}`}
            >
              {area.blurb}
            </p>
            <span
              class={`mt-6 inline-flex items-center gap-1.5 text-sm font-semibold transition-transform group-hover:gap-3 ${area.link}`}
            >
              Explore
              <span aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- About -->
  <section class="mx-auto max-w-5xl px-4 py-20">
    <div class="rounded-3xl bg-pink-50 p-8 sm:p-12">
      <h2 class="text-2xl font-bold text-slate-900 sm:text-3xl">
        A little about me
      </h2>
      <p class="mt-4 max-w-3xl text-lg leading-relaxed text-slate-700">
        I've never been very good at picking just one thing. Over the years I've
        run busy teams, supported people through some of their hardest days, and
        learned to wield a pair of scissors like they owe me money. What ties it
        all together is people: understanding them, helping them, and making
        their day a little brighter.
      </p>
      <p class="mt-4 max-w-3xl text-lg leading-relaxed text-slate-700">
        When I'm not working you'll find me topping up the pink, hunting for the
        perfect coffee, and saying yes to far too many plans.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-5xl px-4 pb-24">
    <div class="rounded-3xl bg-slate-900 px-8 py-14 text-center sm:px-12">
      <h2 class="text-3xl font-bold text-white sm:text-4xl">
        Let's work together
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-lg text-slate-300">
        Got a role, a project or a fringe emergency? I'd love to hear from you.
      </p>
      <a
        href="mailto:summer@example.com"
        class="mt-8 inline-flex items-center gap-2 rounded-full bg-pink-500 px-8 py-4 text-lg font-semibold text-white shadow-lg shadow-pink-500/30 transition hover:bg-pink-400"
      >
        Get in touch
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</Layout>
