---
import Layout from '../layouts/Layout.astro'

const skills = [
  {
    title: 'Team leadership',
    body: 'Building, motivating and growing teams that trust each other and deliver under pressure.',
  },
  {
    title: 'Operations',
    body: 'Designing processes and rotas that keep service running smoothly without the chaos.',
  },
  {
    title: 'People management',
    body: 'One-to-ones, development plans and honest feedback that helps people get better.',
  },
  {
    title: 'Decision-making',
    body: 'Calm, evidence-led calls when the path is unclear and the clock is ticking.',
  },
  {
    title: 'Stakeholder comms',
    body: 'Translating between the floor and the boardroom so everyone pulls the same way.',
  },
  {
    title: 'Change & delivery',
    body: 'Leading projects end to end, from messy idea to measured, repeatable result.',
  },
]

const roles = [
  {
    title: 'Operations Manager',
    org: 'Northgate Group',
    dates: '2021 — Present',
    bullets: [
      'Lead a multi-site team of 12, owning rotas, recruitment and day-to-day performance.',
      'Cut average service turnaround by 28% through a redesigned hand-off process.',
      'Introduced weekly one-to-ones, lifting team retention to its highest level in five years.',
    ],
  },
  {
    title: 'Team Leader',
    org: 'Brightside Services',
    dates: '2018 — 2021',
    bullets: [
      'Managed a front-line team of 6 across two shifts in a fast-paced environment.',
      'Owned the move to a new scheduling system, training the whole team in under a month.',
      'Held the highest customer-satisfaction score in the region for three quarters running.',
    ],
  },
  {
    title: 'Coordinator',
    org: 'Meridian Care Partnership',
    dates: '2016 — 2018',
    bullets: [
      'Coordinated daily operations and acted as the first point of escalation for the team.',
      'Streamlined reporting that previously took half a day down to under an hour.',
    ],
  },
]

const stats = [
  { value: '12', label: 'People led' },
  { value: '5+', label: 'Years managing' },
  { value: '28%', label: 'Turnaround gained' },
  { value: '3', label: 'Teams built' },
]
---

<Layout
  title="Summer — Management & Leadership"
  description="Summer: a confident, people-first manager focused on team leadership, operations and delivery."
  themeClass="bg-slate-950 text-slate-100"
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute -top-32 left-1/2 h-96 w-96 -translate-x-1/2 rounded-full bg-violet-600/30 blur-3xl"
    >
    </div>
    <div class="relative mx-auto max-w-5xl px-4 py-24 sm:py-32">
      <p class="mb-4 inline-flex items-center gap-2 text-sm font-medium tracking-wide text-violet-300">
        <span class="inline-block h-2 w-2 rounded-full bg-pink-500"></span>
        Management &amp; Leadership
      </p>
      <h1 class="text-5xl font-black tracking-tight sm:text-7xl">
        Summer
      </h1>
      <p class="mt-4 max-w-2xl text-xl font-semibold text-violet-200 sm:text-2xl">
        Leading teams to do their best work, calmly and confidently.
      </p>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-300">
        I am a hands-on manager who believes good leadership is mostly about clarity and care.
        I build teams that trust each other, set a direction people can get behind, and keep the
        operation steady when things get busy. Give me a problem and a group of people, and I will
        get you a result you can rely on.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="#contact"
          class="rounded-full bg-violet-600 px-7 py-3 font-semibold text-white shadow-lg shadow-violet-900/40 transition-colors hover:bg-violet-500"
        >
          Work with me
        </a>
        <a
          href="#experience"
          class="rounded-full border border-slate-700 px-7 py-3 font-semibold text-slate-200 transition-colors hover:border-violet-400 hover:text-white"
        >
          See experience
        </a>
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="mx-auto max-w-5xl px-4 py-16 sm:py-20">
    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Strengths</h2>
    <p class="mt-3 max-w-2xl text-slate-400">
      The things I am known for, and the things teams keep coming back to me for.
    </p>
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        skills.map((skill) => (
          <div class="group rounded-2xl border border-slate-800 bg-slate-900/50 p-6 transition-colors hover:border-violet-500/60 hover:bg-slate-900">
            <div class="mb-4 h-1 w-10 rounded-full bg-violet-500 transition-all group-hover:w-16" />
            <h3 class="text-lg font-semibold text-white">{skill.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-400">{skill.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Stats band -->
  <section class="border-y border-violet-900/40 bg-gradient-to-r from-violet-950/60 via-slate-900 to-indigo-950/60">
    <div class="mx-auto grid max-w-5xl grid-cols-2 gap-8 px-4 py-14 sm:grid-cols-4">
      {
        stats.map((stat) => (
          <div class="text-center">
            <div class="text-4xl font-black text-white sm:text-5xl">{stat.value}</div>
            <div class="mt-2 text-sm font-medium uppercase tracking-wide text-violet-300">
              {stat.label}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Experience -->
  <section id="experience" class="mx-auto max-w-5xl px-4 py-16 sm:py-20">
    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Experience</h2>
    <p class="mt-3 max-w-2xl text-slate-400">
      A track record of steady, people-first leadership across busy operations.
    </p>
    <div class="mt-10 space-y-6">
      {
        roles.map((role) => (
          <article class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6 transition-colors hover:border-indigo-500/50 sm:p-8">
            <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
              <h3 class="text-xl font-semibold text-white">
                {role.title}
                <span class="text-violet-300"> · {role.org}</span>
              </h3>
              <span class="text-sm font-medium text-slate-400">{role.dates}</span>
            </div>
            <ul class="mt-4 space-y-2">
              {role.bullets.map((bullet) => (
                <li class="flex gap-3 text-slate-300">
                  <span class="mt-2 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-violet-500" />
                  <span class="leading-relaxed">{bullet}</span>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Philosophy -->
  <section class="mx-auto max-w-5xl px-4 py-16 sm:py-20">
    <div class="rounded-3xl border border-slate-800 bg-slate-900/50 p-8 sm:p-12">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">Leadership philosophy</h2>
      <blockquote class="mt-6 max-w-3xl text-xl font-medium leading-relaxed text-slate-200 sm:text-2xl">
        <span class="text-pink-400">&ldquo;</span>Set the standard, then trust people to meet it.
        My job is to make the path clear, remove what is in the way, and be the calm in the room when
        it counts.<span class="text-pink-400">&rdquo;</span>
      </blockquote>
    </div>
  </section>

  <!-- CTA -->
  <section id="contact" class="mx-auto max-w-5xl px-4 pb-24">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-violet-600 to-indigo-700 p-10 text-center sm:p-16">
      <div
        class="pointer-events-none absolute -bottom-16 -right-16 h-64 w-64 rounded-full bg-pink-500/30 blur-3xl"
      >
      </div>
      <h2 class="relative text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Let&rsquo;s build something steady.
      </h2>
      <p class="relative mx-auto mt-4 max-w-xl text-lg text-violet-100">
        Looking for a manager who leads from the front and keeps the team together? I would love to talk.
      </p>
      <a
        href="mailto:summer@example.com"
        class="relative mt-8 inline-block rounded-full bg-white px-8 py-3.5 font-semibold text-violet-700 shadow-lg transition-transform hover:-translate-y-0.5 hover:bg-violet-50"
      >
        summer@example.com
      </a>
    </div>
  </section>
</Layout>
