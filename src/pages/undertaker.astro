---
import Layout from '../layouts/Layout.astro'

const services = [
  {
    title: 'Funeral planning & arrangements',
    blurb:
      'Thoughtful, unhurried planning that honours your person and reflects exactly who they were, with every detail handled beautifully.',
  },
  {
    title: 'Bereavement support',
    blurb:
      'A steady, listening presence in the days that follow, and gentle guidance towards further support whenever you need it.',
  },
  {
    title: 'Ceremony coordination',
    blurb:
      'Calm, attentive organisation of every part of the day, so you and yours can simply be together.',
  },
  {
    title: 'Pre-arrangement guidance',
    blurb: 'Clear, easy conversations about wishes made in advance. Sort it now, rest easy later.',
  },
  {
    title: 'Repatriation',
    blurb:
      'Careful coordination of every arrangement to bring a loved one home, wherever in the world they may be.',
  },
  {
    title: 'Celebrant introductions',
    blurb:
      'Trusted introductions to celebrants and faith leaders, so you find the right voice to lead a proper send-off.',
  },
]

const approach = [
  {
    title: 'I listen first',
    blurb:
      'Every family is different. Before anything else, I take time to understand your person, your wishes and what really matters to you.',
  },
  {
    title: 'I take the weight off',
    blurb:
      'There is a lot to arrange. I carry the practical details quietly in the background so you can focus on each other.',
  },
  {
    title: 'I honour every wish',
    blurb:
      'No request is too small or too unusual. From a favourite song to neon flowers, I make sure it happens, exactly your way.',
  },
  {
    title: 'I stay close',
    blurb:
      'My support does not end with the service. I am still here afterwards, for as long as you need a familiar face.',
  },
]

const testimonials = [
  {
    quote:
      'Summer guided us through the hardest week of our lives and somehow made us smile too. Nothing was too much trouble.',
    name: 'The Harrow family',
  },
  {
    quote:
      'Calm, kind and gloriously unfussy. Every wish my mother had was honoured perfectly, right down to the pink roses.',
    name: 'Eleanor R.',
  },
  {
    quote:
      'She took the whole weight off our shoulders and let us just be together. A genuinely brilliant, caring human.',
    name: 'James & Priya',
  },
]

const qualifications = [
  'Dip. Funeral Directing',
  'Bereavement care trained',
  'Mortuary care & embalming',
  'Eye for detail',
  'Compassion & patience',
  'Discretion & confidentiality',
  'Faith & cultural awareness',
  'Calm under pressure',
  'Family liaison',
  'Dignity, with personality',
]
---

<Layout
  title="Summer — Funeral Director"
  description="Summer — a funeral director with heart and serious style. Warm, dignified care with a little pink-goth personality."
  themeClass="bg-neutral-950 text-neutral-100"
>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <div
      class="pointer-events-none absolute -top-24 -right-24 h-80 w-80 rounded-full bg-fuchsia-600/20 blur-3xl"
    >
    </div>
    <div
      class="pointer-events-none absolute -bottom-32 -left-24 h-80 w-80 rounded-full bg-pink-500/15 blur-3xl"
    >
    </div>
    <div class="mx-auto grid max-w-5xl gap-12 px-4 py-24 sm:py-28 lg:grid-cols-[1fr_auto] lg:items-center">
      <div>
        <span
          class="inline-flex items-center gap-2.5 rounded-full bg-white/5 px-4 py-1.5 text-sm font-medium tracking-wide text-pink-300 shadow-sm ring-1 ring-pink-500/30"
        >
          <span class="inline-block h-2 w-2 rounded-full bg-pink-500"></span>
          Funeral director & undertaker
        </span>
        <h1 class="mt-7 font-serif text-4xl font-medium tracking-tight text-white sm:text-6xl">
          I'm
          <span
            class="bg-gradient-to-r from-pink-400 via-fuchsia-400 to-rose-400 bg-clip-text text-transparent"
            >Summer</span
          >.
        </h1>
        <p class="mt-3 font-serif text-xl text-pink-200/80 sm:text-2xl">
          Sending people off in style.
        </p>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-neutral-300 sm:text-xl">
          When someone you love dies, everything feels heavy and strange. My job is to walk beside
          you through it: to listen, to handle everything that needs doing, and to help you say
          goodbye in a way that feels truly like them. Warm, unflappable, and not remotely stuffy.
        </p>
        <div class="mt-10 flex items-center gap-4">
          <span class="h-px w-16 bg-gradient-to-r from-pink-500 to-transparent"></span>
          <span class="text-sm uppercase tracking-[0.25em] text-neutral-500">Rest in style</span>
        </div>
      </div>

      <!-- Hero centrepiece: large decorative pink sugar skull -->
      <div class="relative mx-auto lg:mx-0">
        <div
          class="pointer-events-none absolute inset-0 -z-10 rounded-full bg-fuchsia-500/20 blur-2xl"
        >
        </div>
        <svg
          class="h-56 w-56 drop-shadow-[0_0_25px_rgba(236,72,153,0.45)] sm:h-64 sm:w-64"
          viewBox="0 0 100 120"
          fill="none"
          aria-hidden="true"
        >
          <!-- Skull cranium + jaw -->
          <path
            d="M50 8c-22 0-36 16-36 38 0 12 4 20 11 25 2 1.5 3 3 3 6v6c0 6 4 9 10 9h2v-7a4 4 0 0 1 8 0v7h4v-7a4 4 0 0 1 8 0v7h2c6 0 10-3 10-9v-6c0-3 1-4.5 3-6 7-5 11-13 11-25 0-22-14-38-36-38Z"
            fill="#fbcfe8"
            stroke="#ec4899"
            stroke-width="2.5"
          ></path>
          <!-- Eye sockets (hot pink hearts) -->
          <path
            d="M34 52c-6 0-10 4-10 9 0 6 7 10 12 13 5-3 12-7 12-13 0-5-4-9-9-9-2 0-4 1-5 2.5C32.8 53 32.5 52 34 52Z"
            fill="#db2777"
          ></path>
          <path
            d="M66 52c6 0 10 4 10 9 0 6-7 10-12 13-5-3-12-7-12-13 0-5 4-9 9-9 2 0 4 1 5 2.5C67.2 53 67.5 52 66 52Z"
            fill="#db2777"
          ></path>
          <!-- Nose -->
          <path d="M50 64l-5 12h10l-5-12Z" fill="#ec4899"></path>
          <!-- Decorative forehead flower -->
          <circle cx="50" cy="30" r="5" fill="#f472b6"></circle>
          <circle cx="50" cy="22" r="3" fill="#fb7185"></circle>
          <circle cx="42" cy="27" r="3" fill="#fb7185"></circle>
          <circle cx="58" cy="27" r="3" fill="#fb7185"></circle>
          <circle cx="44" cy="34" r="3" fill="#fb7185"></circle>
          <circle cx="56" cy="34" r="3" fill="#fb7185"></circle>
          <!-- Teeth -->
          <g stroke="#ec4899" stroke-width="2">
            <line x1="40" y1="92" x2="40" y2="104"></line>
            <line x1="47" y1="92" x2="47" y2="106"></line>
            <line x1="53" y1="92" x2="53" y2="106"></line>
            <line x1="60" y1="92" x2="60" y2="104"></line>
            <line x1="33" y1="92" x2="67" y2="92"></line>
          </g>
          <!-- Cheek swirls -->
          <path
            d="M28 78c-3 2-3 6 0 8M72 78c3 2 3 6 0 8"
            stroke="#db2777"
            stroke-width="2"
            stroke-linecap="round"></path>
        </svg>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="mx-auto max-w-5xl px-4 pb-8">
    <h2 class="font-serif text-3xl font-medium tracking-tight text-white sm:text-4xl">
      How I can help
    </h2>
    <p class="mt-3 max-w-2xl leading-relaxed text-neutral-400">
      Every farewell is different. Whatever you need, it gets handled with care, zero pressure, and
      at a pace that feels right for you.
    </p>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((service) => (
          <article class="group rounded-2xl border border-white/10 bg-white/[0.03] p-7 shadow-sm transition hover:-translate-y-0.5 hover:border-pink-500/40 hover:bg-white/[0.05]">
            <svg
              class="h-9 w-9 text-pink-400 transition group-hover:scale-110"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M12 2C7.6 2 4 5.4 4 9.8c0 2.6 1.3 4.6 3 6v2.4c0 1 .8 1.8 1.8 1.8.5 0 .9-.5.9-1.1v-1.3a.8.8 0 0 1 1.6 0V20c0 .6.4 1 1 1h1.4c.6 0 1-.4 1-1v-1.6a.8.8 0 0 1 1.6 0v1.3c0 .6.4 1.1.9 1.1 1 0 1.8-.8 1.8-1.8V15.8c1.7-1.4 3-3.4 3-6C20 5.4 16.4 2 12 2Zm-3 9.5a1.8 1.8 0 1 1 0-3.6 1.8 1.8 0 0 1 0 3.6Zm6 0a1.8 1.8 0 1 1 0-3.6 1.8 1.8 0 0 1 0 3.6Zm-3 1.5 1.2 2.4h-2.4L12 13Z" />
            </svg>
            <h3 class="mt-4 font-serif text-xl font-medium text-white">{service.title}</h3>
            <span class="mt-3 block h-px w-10 bg-pink-500/60 transition-all duration-300 group-hover:w-16" />
            <p class="mt-4 leading-relaxed text-neutral-400">{service.blurb}</p>
          </article>
        ))
      }
    </div>
  </section>

  <!-- Approach -->
  <section class="mx-auto max-w-5xl px-4 py-20">
    <div class="relative overflow-hidden rounded-3xl border border-pink-500/20 bg-gradient-to-br from-neutral-900 to-fuchsia-950/40 px-6 py-14 sm:px-14">
      <div
        class="pointer-events-none absolute -top-16 -right-10 h-56 w-56 rounded-full bg-pink-600/10 blur-3xl"
      >
      </div>
      <h2 class="font-serif text-3xl font-medium tracking-tight text-white sm:text-4xl">
        The way I work
      </h2>
      <p class="mt-4 max-w-2xl leading-relaxed text-neutral-300">
        Underneath the pink, it is all about compassion. These are the quiet promises I make to
        every family in my care.
      </p>
      <div class="mt-12 grid gap-x-12 gap-y-10 sm:grid-cols-2">
        {
          approach.map((item) => (
            <div class="flex gap-4">
              <svg
                class="mt-0.5 h-6 w-6 shrink-0 text-pink-400"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M12 2C7.6 2 4 5.4 4 9.8c0 2.6 1.3 4.6 3 6v2.4c0 1 .8 1.8 1.8 1.8.5 0 .9-.5.9-1.1v-1.3a.8.8 0 0 1 1.6 0V20c0 .6.4 1 1 1h1.4c.6 0 1-.4 1-1v-1.6a.8.8 0 0 1 1.6 0v1.3c0 .6.4 1.1.9 1.1 1 0 1.8-.8 1.8-1.8V15.8c1.7-1.4 3-3.4 3-6C20 5.4 16.4 2 12 2Zm-3 9.5a1.8 1.8 0 1 1 0-3.6 1.8 1.8 0 0 1 0 3.6Zm6 0a1.8 1.8 0 1 1 0-3.6 1.8 1.8 0 0 1 0 3.6Z" />
              </svg>
              <div>
                <h3 class="font-serif text-xl font-medium text-white">{item.title}</h3>
                <p class="mt-2 leading-relaxed text-neutral-300">{item.blurb}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="mx-auto max-w-5xl px-4 pb-20">
    <h2 class="font-serif text-3xl font-medium tracking-tight text-white sm:text-4xl">
      What families say
    </h2>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {
        testimonials.map((t) => (
          <figure class="flex flex-col rounded-2xl border border-white/10 bg-white/[0.03] p-7 shadow-sm">
            <svg
              class="h-7 w-7 text-pink-400"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M9.5 7C6.5 7 4 9.5 4 12.7c0 2.8 2 4.8 4.6 4.8 1.4 0 2.3-.7 2.3-1.8 0-1-.7-1.6-1.7-1.6-.3 0-.6.1-.8.1.2-1.6 1.6-3 3.4-3.3.4-.1.6-.4.6-.8V7.8c0-.5-.4-.8-.9-.8Zm9 0C15.5 7 13 9.5 13 12.7c0 2.8 2 4.8 4.6 4.8 1.4 0 2.3-.7 2.3-1.8 0-1-.7-1.6-1.7-1.6-.3 0-.6.1-.8.1.2-1.6 1.6-3 3.4-3.3.4-.1.6-.4.6-.8V7.8c0-.5-.4-.8-.9-.8Z" />
            </svg>
            <blockquote class="mt-4 flex-1 font-serif text-base italic leading-relaxed text-neutral-200">
              {t.quote}
            </blockquote>
            <figcaption class="mt-6 text-sm font-medium tracking-wide text-pink-300">
              — {t.name}
            </figcaption>
          </figure>
        ))
      }
    </div>
  </section>

  <!-- Qualifications -->
  <section class="mx-auto max-w-5xl px-4 pb-20">
    <div class="rounded-3xl border border-white/10 bg-white/[0.03] px-6 py-12 shadow-sm sm:px-12">
      <h2 class="font-serif text-3xl font-medium tracking-tight text-white sm:text-4xl">
        Training & qualifications
      </h2>
      <p class="mt-3 max-w-2xl leading-relaxed text-neutral-400">
        Properly trained and quietly obsessive about doing things right, with skill, care and
        respect at every stage.
      </p>
      <ul class="mt-8 flex flex-wrap gap-3">
        {
          qualifications.map((q) => (
            <li class="inline-flex items-center gap-2 rounded-full border border-pink-500/20 bg-pink-500/5 px-4 py-2 text-sm font-medium text-pink-100 transition hover:border-pink-500/50 hover:bg-pink-500/10">
              <svg
                class="h-3.5 w-3.5 text-pink-400"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M12 2C7.6 2 4 5.4 4 9.8c0 2.6 1.3 4.6 3 6v2.4c0 1 .8 1.8 1.8 1.8.5 0 .9-.5.9-1.1v-1.3a.8.8 0 0 1 1.6 0V20c0 .6.4 1 1 1h1.4c.6 0 1-.4 1-1v-1.6a.8.8 0 0 1 1.6 0v1.3c0 .6.4 1.1.9 1.1 1 0 1.8-.8 1.8-1.8V15.8c1.7-1.4 3-3.4 3-6C20 5.4 16.4 2 12 2Zm-3 9.5a1.8 1.8 0 1 1 0-3.6 1.8 1.8 0 0 1 0 3.6Zm6 0a1.8 1.8 0 1 1 0-3.6 1.8 1.8 0 0 1 0 3.6Z" />
              </svg>
              {q}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="mx-auto max-w-5xl px-4 pb-28">
    <div class="relative overflow-hidden rounded-3xl border border-pink-500/30 bg-gradient-to-br from-fuchsia-950/60 to-neutral-900 px-6 py-16 text-center shadow-sm sm:px-12">
      <div
        class="pointer-events-none absolute -bottom-16 left-1/2 h-56 w-56 -translate-x-1/2 rounded-full bg-pink-600/15 blur-3xl"
      >
      </div>
      <svg
        class="mx-auto h-14 w-14 text-pink-400 drop-shadow-[0_0_15px_rgba(236,72,153,0.5)]"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M12 2C7.6 2 4 5.4 4 9.8c0 2.6 1.3 4.6 3 6v2.4c0 1 .8 1.8 1.8 1.8.5 0 .9-.5.9-1.1v-1.3a.8.8 0 0 1 1.6 0V20c0 .6.4 1 1 1h1.4c.6 0 1-.4 1-1v-1.6a.8.8 0 0 1 1.6 0v1.3c0 .6.4 1.1.9 1.1 1 0 1.8-.8 1.8-1.8V15.8c1.7-1.4 3-3.4 3-6C20 5.4 16.4 2 12 2Zm-3 9.5a1.8 1.8 0 1 1 0-3.6 1.8 1.8 0 0 1 0 3.6Zm6 0a1.8 1.8 0 1 1 0-3.6 1.8 1.8 0 0 1 0 3.6Zm-3 1.5 1.2 2.4h-2.4L12 13Z" />
      </svg>
      <h2 class="mt-5 font-serif text-3xl font-medium tracking-tight text-white sm:text-4xl">
        Let's have a quiet chat
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-lg leading-relaxed text-neutral-300">
        No rush, no obligation. Whenever you feel ready, drop me a line and we'll talk things through
        gently, in your own time.
      </p>
      <a
        href="mailto:summer@example.com"
        class="mt-9 inline-flex items-center gap-2.5 rounded-full bg-gradient-to-r from-pink-500 to-fuchsia-600 px-8 py-4 text-lg font-semibold text-white shadow-lg shadow-pink-500/30 transition hover:-translate-y-0.5 hover:shadow-pink-500/50 focus:outline-none focus-visible:ring-4 focus-visible:ring-pink-400/50"
      >
        Talk to me
      </a>
      <p class="mt-6 text-sm text-neutral-500">summer@example.com</p>
    </div>
  </section>
</Layout>
